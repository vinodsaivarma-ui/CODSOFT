    def get_response(self, user_input):
        
        normalized_input = user_input.lower().strip()
        

        for category, rule_data in self.rules.items():
            if category == 'default':
                continue
            for pattern in rule_data['patterns']:
                
                if pattern == normalized_input or pattern in normalized_input:
                    
                    return random.choice(rule_data['responses'])

        return random.choice(self.rules['default']['responses'])
    
    def chat(self):
        
        print("=== Simple Rule-Based Chatbot ===")
        print("I respond to predefined rules. Type 'bye' to exit.")
        print("Try: hello, what is your name, help, joke, weather\n")
        
        while True:

            user_input = input("You: ")
            
            response = self.get_response(user_input)
            print(f"ChatBot: {response}")
            print()
            if user_input.lower().strip() in ['bye', 'goodbye', 'exit', 'quit']:
                break

