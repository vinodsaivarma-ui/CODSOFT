import os
import numpy as np
import tensorflow as tf
from tensorflow.keras.applications import ResNet50
from tensorflow.keras.applications.resnet50 import preprocess_input
from tensorflow.keras.preprocessing.sequence import pad_sequences
from tensorflow.keras.preprocessing.text import Tokenizer
from tensorflow.keras.models import Model
from tensorflow.keras.layers import Input, Dense, LSTM, Embedding, Dropout, Add

def load_captions_file(filename):
    with open(filename, 'r', encoding='utf-8') as f:
        lines = f.read().strip().split('\n')

    mapping = {}
    for line in lines:
        tokens = line.split(',')
        if len(tokens) < 2:
            continue
        image_id = tokens[0].strip()
        caption = ",".join(tokens[1:]).strip().lower()

        image_id = image_id.split('#')[0]

        if image_id not in mapping:
            mapping[image_id] = []

        caption = 'startseq ' + caption + ' endseq'
        mapping[image_id].append(caption)

    return mapping

def build_tokenizer(captions_mapping):
    all_captions = []
    for caps in captions_mapping.values():
        all_captions.extend(caps)

    tokenizer = Tokenizer(oov_token="<unk>")
    tokenizer.fit_on_texts(all_captions)
    return tokenizer

def max_caption_length(captions_mapping):
    return max(len(caption.split()) for caps in captions_mapping.values() for caption in caps)

def build_feature_extractor():
    base_model = ResNet50(weights='imagenet', include_top=False, pooling='avg')
    model = Model(inputs=base_model.input, outputs=base_model.output)
    return model

def extract_features(images_dir, image_ids, model):
    features = {}
    for image_id in image_ids:
        img_path = os.path.join(images_dir, image_id)
        if not os.path.exists(img_path):
            continue

        img = tf.keras.preprocessing.image.load_img(img_path, target_size=(224, 224))
        img = tf.keras.preprocessing.image.img_to_array(img)
        img = np.expand_dims(img, axis=0)
        img = preprocess_input(img)

        feature = model.predict(img, verbose=0)
        features[image_id] = feature[0]

    return features

def create_sequences(tokenizer, max_len, captions_list, photo_feature, vocab_size):
    X1, X2, y = [], [], []

    for caption in captions_list:
        seq = tokenizer.texts_to_sequences([caption])[0]

        for i in range(1, len(seq)):
            in_seq, out_seq = seq[:i], seq[i]
            in_seq = pad_sequences([in_seq], maxlen=max_len)[0]
            out_seq = tf.keras.utils.to_categorical([out_seq], num_classes=vocab_size)[0]

            X1.append(photo_feature)
            X2.append(in_seq)
            y.append(out_seq)

    return np.array(X1), np.array(X2), np.array(y)

def data_generator(captions_mapping, features, tokenizer, max_len, vocab_size, batch_size=32):
    image_ids = list(captions_mapping.keys())

    while True:
        X1_batch, X2_batch, y_batch = [], [], []

        for image_id in image_ids:
            if image_id not in features:
                continue

            photo_feature = features[image_id]
            captions_list = captions_mapping[image_id]

            X1, X2, y = create_sequences(tokenizer, max_len, captions_list, photo_feature, vocab_size)

            for i in range(len(X1)):
                X1_batch.append(X1[i])
                X2_batch.append(X2[i])
                y_batch.append(y[i])

                if len(X1_batch) == batch_size:
                    yield ({"image_input": np.array(X1_batch), "text_input": np.array(X2_batch)}, np.array(y_batch))
                    X1_batch, X2_batch, y_batch = [], [], []

def define_model(vocab_size, max_len):
    # image feature branch
    inputs1 = Input(shape=(2048,), name="image_input")
    fe1 = Dropout(0.5)(inputs1)
    fe2 = Dense(256, activation='relu')(fe1)

    inputs2 = Input(shape=(max_len,), name="text_input")
    se1 = Embedding(vocab_size, 256, mask_zero=True)(inputs2)
    se2 = Dropout(0.5)(se1)
    se3 = LSTM(256)(se2)

    decoder1 = Add()([fe2, se3])
    decoder2 = Dense(256, activation='relu')(decoder1)
    outputs = Dense(vocab_size, activation='softmax')(decoder2)

    model = Model(inputs=[inputs1, inputs2], outputs=outputs)
    model.compile(loss='categorical_crossentropy', optimizer='adam')

    return model

def idx_to_word(integer, tokenizer):
    for word, index in tokenizer.word_index.items():
        if index == integer:
            return word
    return None

def generate_caption(model, tokenizer, photo_feature, max_len):
    in_text = 'startseq'

    for _ in range(max_len):
        sequence = tokenizer.texts_to_sequences([in_text])[0]
        sequence = pad_sequences([sequence], maxlen=max_len)

        yhat = model.predict([np.expand_dims(photo_feature, axis=0), sequence], verbose=0)
        yhat = np.argmax(yhat)

        word = idx_to_word(yhat, tokenizer)
        if word is None:
            break

        in_text += ' ' + word

        if word == 'endseq':
            break

    return in_text.replace('startseq', '').replace('endseq', '').strip()

if __name__ == "__main__":
    captions_file = "captions.txt"      # Flickr8k captions file
    images_dir = "Images"               # folder containing images

    captions_mapping = load_captions_file(captions_file)
    tokenizer = build_tokenizer(captions_mapping)

    vocab_size = len(tokenizer.word_index) + 1
    max_len = max_caption_length(captions_mapping)

    print("Vocabulary Size:", vocab_size)
    print("Max Caption Length:", max_len)

    feature_extractor = build_feature_extractor()
    image_ids = list(captions_mapping.keys())
    features = extract_features(images_dir, image_ids, feature_extractor)

    model = define_model(vocab_size, max_len)
    model.summary()

    batch_size = 32
    steps = max(1, len(features) // batch_size)

    generator = data_generator(captions_mapping, features, tokenizer, max_len, vocab_size, batch_size)

    model.fit(generator, epochs=10, steps_per_epoch=steps, verbose=1)

    model.save("image_caption_model.h5")

    sample_image = image_ids[0]
    if sample_image in features:
        caption = generate_caption(model, tokenizer, features[sample_image], max_len)
        print(f"Generated Caption for {sample_image}: {caption}")
